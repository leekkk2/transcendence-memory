# Canonical runtime is transcendence-memory-server/scripts/run_task_rag_server.sh
# This env file is a systemd-facing wrapper around that private runtime.

# Required runtime auth / embedding keys
RAG_API_KEY=replace-me
EMBEDDING_API_KEY=replace-me

# Optional runtime location override.
# If omitted, run_task_rag_server.sh defaults WORKSPACE to the server repo root.
# Set this only when you intentionally want monorepo-root runtime data paths.
# WORKSPACE=/opt/skills-workspace

# Optional embedding endpoint overrides.
# Current runtime resolves: EMBEDDING_BASE_URL -> EMBEDDINGS_BASE_URL -> default.
# To avoid alias drift, set both to the same value when overriding.
# EMBEDDING_BASE_URL=https://newapi.example.com/v1
# EMBEDDINGS_BASE_URL=https://newapi.example.com/v1
